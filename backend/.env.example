# ============================================================
# Healthcare Platform — Backend Environment Variables
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql://healthcare:healthcare_dev@localhost:5432/healthcare_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change-me-to-a-strong-random-string
JWT_REFRESH_SECRET=change-me-to-another-strong-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Admin Seed ----
ADMIN_EMAIL=admin@healthcare.local
ADMIN_PASSWORD=Admin123!

# ---- Server ----
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ---- Anthropic (Claude) LLM ----
ANTHROPIC_API_KEY=

# ---- Email ----
# Options: nodemailer | sendgrid
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# ---- Google Calendar OAuth 2.0 ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ---- Encryption (for Google tokens at rest) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ---- Slot Hold ----
SLOT_HOLD_MINUTES=5
